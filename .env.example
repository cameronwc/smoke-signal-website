# Smoke Signal Website — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# (Optional) Analytics tracking ID — uncomment and set when analytics is added
# ANALYTICS_ID=

# (Optional) Email collection API endpoint — replace the console.log in index.html
# with a fetch() to this URL when a real signup backend is configured
# EMAIL_SIGNUP_ENDPOINT=https://your-api.example.com/subscribe

# (Optional) App Store URL — update the modal and CTA buttons when the app is published
# APP_STORE_URL=https://apps.apple.com/app/smoke-signal/idXXXXXXXXXX

# (Optional) TestFlight URL — use as interim before App Store publication
# TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXX
